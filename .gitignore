# ============================================================================
# Terminal Eighty â€” .gitignore
#
# Convention: tracked-by-design exceptions are listed near the rules that
# would otherwise hide them, so future maintainers see the WHY inline.
# ============================================================================

# ----------------------------------------------------------------------------
# Hugo build artifacts (regenerated by `hugo` and by deploy.yml)
# ----------------------------------------------------------------------------
site/public/
site/resources/_gen/
.hugo_build.lock

# Phase 5e â€” redirects emitter marker dir (regenerated each build)
site/static/.t80-redirects/

# Phase 6 â€” publish-time generated media data (rebuilt by admin publish step)
# Keep it out of source control; the live values live on the Pi's media DB.
site/data/media.json

# ----------------------------------------------------------------------------
# Node / npm / package managers
#
# Root and migrate/ node_modules are dev-only and never deployed.
# admin/node_modules/ IS intentionally tracked so the Pi can deploy via
# `git pull` without running `npm install`. Do NOT add a /node_modules/
# rule that would hide it.
# ----------------------------------------------------------------------------
/node_modules/
/migrate/node_modules/
.npm/
.yarn/
.pnpm-store/
*.tgz
.npmrc.local

# Logs from any tooling
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# Runtime
pids/
*.pid
*.seed
*.pid.lock

# Coverage + caches
coverage/
.nyc_output/
lib-cov/
.cache/
.parcel-cache/
.vite/
.eslintcache
.stylelintcache
.prettiercache
*.tsbuildinfo

# ----------------------------------------------------------------------------
# Test + CI artifacts
# ----------------------------------------------------------------------------
playwright-report/
test-results/
playwright/.cache/
.lighthouseci/
lighthouse-report.*

# ----------------------------------------------------------------------------
# Admin runtime state (production data â€” never commit)
# ----------------------------------------------------------------------------
admin/data/
admin/data/auth.db
admin/data/auth.db-*
admin/data/auth-dev.db
admin/data/auth-dev.db-*
admin/data/test-*.db
admin/data/test-*.db-*
admin/data/*.sqlite
admin/data/*.sqlite-*
admin/uploads/
admin/.env
admin/logs/

# ----------------------------------------------------------------------------
# Secrets + environment files
#
# Always commit `.env.example` / `.env.dev.example`; never commit real `.env`.
# ----------------------------------------------------------------------------
.env
.env.*
!.env.example
!.env.*.example
docker/.env
docker/.env.dev
docker/.env.*
!docker/.env.example
!docker/.env.*.example

# Credentials / keys (defensive â€” repo holds no secrets today)
*.pem
*.key
!**/fonts/*.key
*.crt
*.p12
*.pfx
id_rsa
id_ed25519
*_rsa
*_ed25519
service-account*.json

# ----------------------------------------------------------------------------
# Design / scratch / WIP
# ----------------------------------------------------------------------------
# /Blog/ held the v7 + Admin v2 mockups during Phases 1-2. Phase 13 deleted
# them; this rule prevents accidental re-add when iterating on new designs.
Blog/
*.sketch
*.fig
scratch/
tmp/
.tmp/

# ----------------------------------------------------------------------------
# Husky internals (regenerated by `husky init`)
# ----------------------------------------------------------------------------
.husky/_/

# ----------------------------------------------------------------------------
# Editor / IDE
# ----------------------------------------------------------------------------
.vscode/
!.vscode/settings.json.example
!.vscode/extensions.json.example
.idea/
*.iml
*.ipr
*.iws
.fleet/
.zed/
.history/
.sublime-*
*.sublime-workspace

# Vim / Emacs / other terminal editors
*.swp
*.swo
*.swn
*~
\#*\#
.\#*

# JetBrains shelved changes
.idea_modules/
shelf/

# ----------------------------------------------------------------------------
# OS junk
# ----------------------------------------------------------------------------
# macOS
.DS_Store
.DS_Store?
.AppleDouble
.LSOverride
.Spotlight-V100
.Trashes
Icon?
._*

# Windows
Thumbs.db
Thumbs.db:encryptable
ehthumbs.db
ehthumbs_vista.db
Desktop.ini
$RECYCLE.BIN/
*.lnk

# Linux
.directory
.Trash-*
.nfs*

# ----------------------------------------------------------------------------
# Backup / merge / scratch files
# ----------------------------------------------------------------------------
*.bak
*.orig
*.rej
*.old

# macOS Finder duplicate-on-copy pattern: "filename 2.ext"
# (Don't blanket-ignore â€” would catch legitimate "Part 2.md" posts.)
# If admin/node_modules accumulates these, prune via Phase 13's npm-rebuild.

# ----------------------------------------------------------------------------
# Python (scripts/ uses python3 for one-off helpers)
# ----------------------------------------------------------------------------
__pycache__/
*.py[cod]
*$py.class
.Python
.venv/
venv/
env/
.pytest_cache/
.mypy_cache/

# ----------------------------------------------------------------------------
# Docker local overrides (production compose is checked in; local overrides
# stay personal)
# ----------------------------------------------------------------------------
docker-compose.override.yml
docker-compose.local.yml

# ----------------------------------------------------------------------------
# Local-dev convenience files
# ----------------------------------------------------------------------------
*.local
.local/

# Notes / TODOs scratch files (real planning lives in PRs + CONTRIBUTING.md)
NOTES.md
TODO.md
SCRATCH.md
