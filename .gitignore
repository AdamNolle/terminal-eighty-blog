# Hugo build output (rebuilt by CI)
site/public/
site/resources/_gen/

# macOS noise
.DS_Store

# Editor scratch
.vscode/
.idea/

# Root tooling node_modules (admin/node_modules is intentionally tracked
# so the Pi can deploy via git clone without running npm install)
/node_modules/
/migrate/node_modules/

# Test + CI artifacts
coverage/
playwright-report/
test-results/
.lighthouseci/

# Auth + uploads (production data)
admin/data/
admin/data/auth.db
admin/data/auth.db-*
admin/data/auth-dev.db
admin/data/auth-dev.db-*
admin/uploads/

# Local env files
.env
.env.local
docker/.env
docker/.env.dev

# Husky internals (regenerated by `husky init`)
.husky/_/
