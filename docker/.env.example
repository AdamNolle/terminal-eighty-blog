# ── Domains ──
DOMAIN_ADMIN=admin.terminaleighty.com
DOMAIN_COMMENTS=comments.terminaleighty.com
DOMAIN_ANALYTICS=analytics.terminaleighty.com

# ── Cloudflare ──
# Get this from Cloudflare Zero Trust Dashboard
CLOUDFLARE_TUNNEL_TOKEN=your-token-here

# ── CMS Auth ──
# Generate a random string: openssl rand -base64 32
CMS_SESSION_SECRET=replace-me-with-random-string

# ── Remark42 ──
# Generate a random string: openssl rand -base64 32
REMARK42_SECRET=replace-me-with-random-string
REMARK42_ADMIN_ID=admin

# ── Umami ──
# Generate a random string: openssl rand -base64 32
UMAMI_SECRET=replace-me-with-random-string
# Database password
UMAMI_DB_PASSWORD=replace-me-with-secure-password
