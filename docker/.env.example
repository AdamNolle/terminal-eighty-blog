# ── Domains ──
DOMAIN_ADMIN=admin.terminaleighty.com
DOMAIN_COMMENTS=comments.terminaleighty.com
DOMAIN_ANALYTICS=analytics.terminaleighty.com

# ── Cloudflare ──
# Get this from Cloudflare Zero Trust Dashboard
CLOUDFLARE_TUNNEL_TOKEN=your-token-here

# ── CMS Auth ──
# Generate a random string: openssl rand -base64 32
CMS_SESSION_SECRET=replace-me-with-random-string

# ── Remark42 ──
# Generate a random string: openssl rand -base64 32
REMARK42_SECRET=replace-me-with-random-string
REMARK42_ADMIN_ID=admin

# ── Umami ──
# Generate a random string: openssl rand -base64 32
UMAMI_SECRET=replace-me-with-random-string
# Database password
UMAMI_DB_PASSWORD=replace-me-with-secure-password

# ── Bluesky / AT Protocol (Phase 9) ──
# Generate an app-password at https://bsky.app/settings/app-passwords
# NEVER paste the main account password here — Bluesky app-passwords
# are revocable per-app and can't change account settings.
BLUESKY_HANDLE=blog.terminaleighty.com
BLUESKY_APP_PASSWORD=
# Override the PDS if you self-host. Default is bsky.social.
# BLUESKY_SERVICE=https://bsky.social
# Don't cross-post posts older than this (ms). Default 1 hour — stops
# a content edit from re-spamming a year-old post.
# BLUESKY_MAX_AGE_MS=3600000
# Hard cap on cross-posts per publish run. Default 5.
# BLUESKY_MAX_PER_RUN=5
# Used to build the post URL in the cross-post text. Defaults to
# https://terminaleighty.com.
# PUBLIC_BASE_URL=https://terminaleighty.com
