# Local dev only — these are throwaway values. Copy to .env.dev and
# commit nothing.
#
# WebAuthn — rpID=localhost works on every browser without HTTPS.
# auth.js reads WEBAUTHN_RP_ID first, falling back to RP_ID (which the
# production compose file uses). Same for WEBAUTHN_ORIGIN / ORIGIN.
WEBAUTHN_RP_ID=localhost
WEBAUTHN_ORIGIN=http://localhost:3000
WEBAUTHN_RP_NAME=Terminal Eighty (dev)

# Session cookie signing (≥ 32 chars or cookie-parser warns).
CMS_SESSION_SECRET=dev-session-secret-32-chars-minimum-foo
SESSION_SECRET=dev-session-secret-32-chars-minimum-foo

# Auth DB — keep dev data outside admin/data/auth.db so it can't shadow
# a real account if you ever symlink the prod data dir for inspection.
AUTH_DB_PATH=admin/data/auth-dev.db

# Conversion worker — keep it on for end-to-end testing; flip to `off`
# if you want quieter logs.
CONVERSION_WORKER=on
CONVERSION_CONCURRENCY=2
MEDIA_MAX_UPLOAD_SIZE=104857600

# Hugo
HUGO_BASE_URL=http://localhost:1313

# Comments + analytics — match the dev-stack ports.
REMARK42_URL=http://localhost:8081
UMAMI_URL=http://localhost:3001
UMAMI_SITE_ID=

# Bluesky cross-post — leave empty in dev unless you're testing the
# integration path (Phase 5e+).
BLUESKY_HANDLE=
BLUESKY_APP_PASSWORD=
