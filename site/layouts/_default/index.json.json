{{- $.Scratch.Add "index" slice -}}
{{- range where .Site.RegularPages "Section" "posts" -}}
  {{- if not .Draft -}}
    {{- $.Scratch.Add "index" (dict "title" .Title "date" (.Date.Format "2006-01-02") "url" .Permalink "tags" .Params.tags "content" (.Plain | truncate 300) "description" .Description) -}}
  {{- end -}}
{{- end -}}
{{- $.Scratch.Get "index" | jsonify -}}
